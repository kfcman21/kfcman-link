  <!-- Toast Notification System -->
  <div class="toast-container" id="toast-container"></div>
              <tbody id="stats-clicks-log-body">
                <!-- Dynamically populated rows -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Preference Poll Voting & Statistics Modal -->
  <div class="modal-overlay hidden" id="poll-vote-modal">
    <div class="modal-content glass-panel stats-modal-content animate-scale-up" style="max-width: 600px;">
      <button class="modal-close" id="btn-poll-modal-close" aria-label="닫기">
        <i data-lucide="x"></i>
      </button>
      
      <div class="stats-modal-header" style="border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 16px; margin-bottom: 20px;">
        <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
          <span class="stats-badge" id="poll-modal-badge-status" style="background: rgba(16, 185, 129, 0.15); color: var(--color-green);">진행중</span>
          <span class="stats-badge" id="poll-modal-badge-multiple" style="background: rgba(6, 182, 212, 0.15); color: var(--color-cyan);">단수 선택</span>
          <span class="stats-badge" id="poll-modal-badge-dup" style="background: rgba(234, 179, 8, 0.15); color: var(--color-yellow);">평생 1회 제한</span>
        </div>
        <h3 class="modal-title" id="poll-modal-title" style="margin-top: 12px; font-size: 20px; font-weight: 700; line-height: 1.4; color: var(--text-main);">선호도 조사 주제</h3>
        <p class="modal-desc" style="font-size: 12px; margin-top: 4px;">등록자: <span id="poll-modal-owner" style="color: var(--color-cyan); font-weight: 600;">kfcman</span> | 제한시간: <span id="poll-modal-timer" style="color: #ff9f43; font-weight: 700;">로딩 중...</span></p>
        
        <!-- Premium copyable guest sharing URL bar -->
        <div id="poll-modal-share-bar" style="margin-top: 12px; display: flex; align-items: center; gap: 8px; background: var(--bg-primary); border: 1px solid var(--border-glass); padding: 5px 10px; border-radius: 8px;">
          <span style="font-size: 11px; color: var(--text-muted); font-weight: 600; flex-shrink: 0; display: inline-flex; align-items: center; gap: 4px;"><i data-lucide="link" style="width: 12px; height: 12px;"></i> 공유 주소:</span>
          <input type="text" id="poll-modal-share-url" readonly style="flex: 1; background: transparent; border: none; outline: none; color: var(--color-cyan); font-size: 12.5px; font-weight: 600; padding: 2px 0; cursor: default; min-width: 0;" value="http://kfcman.link/?poll=...">
          <button type="button" class="btn btn-glass btn-sm" id="btn-copy-modal-poll-url" style="height: 24px; padding: 0 8px; font-size: 11px; border-radius: 5px; display: inline-flex; align-items: center; gap: 4px; flex-shrink: 0;">
            <i data-lucide="copy" style="width: 11px; height: 11px;"></i> <span>복사</span>
          </button>
        </div>
      </div>
          <button type="submit" class="btn btn-primary w-full" id="btn-submit-vote" style="font-weight: 700; height: 48px;">
            <span>투표 제출하기</span>
            <i data-lucide="check-circle-2"></i>
          </button>
        </form>
      </div>

      <!-- Statistics Screen Container -->
      <div id="poll-modal-stats-screen" class="hidden">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; flex-wrap: wrap; gap: 10px;">
          <!-- Custom Visual Tab Switcher Buttons -->
          <div class="poll-view-tabs" style="display: flex; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.06); padding: 4px; border-radius: 10px; gap: 4px;">
            <button type="button" class="btn-glass btn-sm active" id="btn-poll-view-bar" style="height: 30px; padding: 0 10px; font-size: 12px; border: none; border-radius: 6px; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; transition: var(--transition-fast);">
              <i data-lucide="bar-chart-3" style="width: 13px; height: 13px;"></i> <span>막대그래프</span>
            </button>
            <button type="button" class="btn-glass btn-sm" id="btn-poll-view-donut" style="height: 30px; padding: 0 10px; font-size: 12px; border: none; border-radius: 6px; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; transition: var(--transition-fast);">
              <i data-lucide="pie-chart" style="width: 13px; height: 13px;"></i> <span>원형 도넛</span>
            </button>
            <button type="button" class="btn-glass btn-sm" id="btn-poll-view-cloud" style="height: 30px; padding: 0 10px; font-size: 12px; border: none; border-radius: 6px; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; transition: var(--transition-fast);">
              <i data-lucide="cloud" style="width: 13px; height: 13px;"></i> <span>워드클라우드</span>
            </button>
        <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 16px; border-top: 1px dashed rgba(255,255,255,0.08); font-size: 13px; color: var(--text-muted);">
          <span>참여 인원: <strong id="poll-modal-total-votes" style="color: #ffffff;">0명</strong></span>
          <span id="poll-voted-notice" style="color: var(--color-green); font-weight: 600; display: flex; align-items: center; gap: 4px;"><i data-lucide="check-check" style="width: 14px; height: 14px;"></i> 이미 투표에 참여하셨습니다.</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast Notification System -->
  <div class="toast-container" id="toast-container"></div>

  <!-- Global Icons Init -->
  <script>
    lucide.createIcons();
  </script>









