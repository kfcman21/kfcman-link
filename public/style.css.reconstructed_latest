/* ==========================================================================
   kfcman.link URL Shortener Premium Design System
   ========================================================================== */

/* Variables & Base Customization */
:root {
  --bg-primary: #070a13;
  --bg-secondary: #0c1122;
  --bg-glass: rgba(12, 17, 34, 0.65);
  --border-glass: rgba(255, 255, 255, 0.07);
  --border-glass-hover: rgba(255, 255, 255, 0.15);
  
  --primary-gradient: linear-gradient(135deg, #7c3aed 0%, #06b6d4 100%);
  --secondary-gradient: linear-gradient(135deg, #1f2937 0%, #111827 100%);
  --danger-gradient: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
  
  --color-purple: #8b5cf6;
  --color-cyan: #06b6d4;
  --color-green: #10b981;
  --color-red: #ef4444;
  --color-yellow: #f59e0b;
  
  --text-main: #f3f4f6;
  --text-muted: #9ca3af;
  --text-dark: #1f2937;
  
  --shadow-glow-purple: 0 0 25px rgba(139, 92, 246, 0.35);
  --shadow-glow-cyan: 0 0 25px rgba(6, 182, 212, 0.35);
  --shadow-premium: 0 20px 50px rgba(0, 0, 0, 0.4);
  
  --font-title: 'Outfit', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  --font-body: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  
  --transition-smooth: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-fast: all 0.15s ease;
}

/* Reset */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
}

body {
  background-color: var(--bg-primary);


























































































































































































































































































































































































































































































































































































































































































}

.result-field.local-field .result-copy {
  border-color: rgba(139, 92, 246, 0.3);
}

.url-display {
  font-family: var(--font-body);
  font-size: 16px;
  font-weight: 600;
  color: var(--text-main);
  overflow-x: auto;
  white-space: nowrap;
  padding-right: 12px;
}

/* Hide scrollbar for Display */
.url-display::-webkit-scrollbar {
  display: none;
}

.result-footer {
  display: flex;
  gap: 16px;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  padding-top: 24px;
}

/* Dashboard Section */
.dashboard-section {
  padding: 40px 0 0 0;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  margin-top: 40px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 28px;
}

.section-title {
  font-family: var(--font-title);
  font-size: 24px;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--text-main);
}

.section-title i {
  color: var(--color-purple);
}

.section-subtitle {
  font-size: 13px;
  color: var(--text-muted);
  margin-top: 4px;
}

/* Stats Summary Panel */
.dashboard-summary {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 20px;
  margin-bottom: 28px;
}

.stat-card {
  padding: 24px;
  display: flex;
  align-items: center;
  gap: 20px;
}

.stat-icon {
  width: 52px;
  height: 52px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;







































  .footer-content {
    flex-direction: column;
    text-align: center;
  }
}

















































































































































































































































































































































































































































































































































































































































  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.5;
}

/* ==========================================================================
   LIGHT MODE STYLES (Update)
   ========================================================================== */
body.light-theme {
  --bg-primary: #f3f4f6;
  --bg-secondary: #ffffff;
  --bg-glass: rgba(255, 255, 255, 0.72);
  --border-glass: rgba(0, 0, 0, 0.08);
  --border-glass-hover: rgba(0, 0, 0, 0.16);
  
  --text-main: #1f2937;
  --text-muted: #6b7280;
  --shadow-premium: 0 20px 40px rgba(0, 0, 0, 0.06);
  
  background-color: var(--bg-primary);
  color: var(--text-main);
}

/* Light mode orb adjustments to soft pastel blobs */
body.light-theme .glow-orb {
  opacity: 0.16;
  filter: blur(100px);
}

body.light-theme .orb-1 {
  background: radial-gradient(circle, var(--color-purple) 0%, transparent 70%);
}

body.light-theme .orb-2 {
  background: radial-gradient(circle, var(--color-cyan) 0%, transparent 70%);
}

body.light-theme .app-header {
  background: rgba(243, 244, 246, 0.8);
  border-bottom: 1px solid var(--border-glass);
}