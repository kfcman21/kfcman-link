    <!-- User Dashboard Section -->
    <section class="dashboard-section" id="dashboard-section">
      <div class="section-header">
        <div>
          <h2 class="section-title"><i data-lucide="layout-dashboard"></i> 내 링크 대시보드</h2>
          <p class="section-subtitle">현재 브라우저에서 생성한 단축 링크 목록과 실시간 성과 지표입니다.</p>
