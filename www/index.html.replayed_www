  <!-- Admin Login Screen (Displayed when not logged in) -->
  <div class="login-screen-overlay" id="login-container">
    <div class="login-card glass-panel animate-scale-up">
      <div class="login-header">
        <div class="login-icon-badge">
          <i data-lucide="lock"></i>
        </div>
        <h2 class="login-title">KFCMan.link 인증</h2>
        <p class="login-desc">
          이 시스템은 관리자 전용으로 운영됩니다.<br>단축 링크 생성 및 대시보드를 열람하려면 비밀번호를 입력하세요.
        </p>
      </div>
      <form id="login-form">
        <div class="input-group">
          <div class="input-icon">
            <i data-lucide="key-round"></i>
          </div>
          <input type="password" id="password-input" placeholder="관리자 비밀번호 입력..." required autocomplete="current-password">
          <button type="submit" class="btn btn-primary" id="login-btn">
            <span>확인</span>
            <i data-lucide="arrow-right"></i>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Main Hero & URL Shortener Section (Hidden until logged in) -->
  <main class="container hidden" id="main-content">
    <section class="hero-section" id="shortener-section">
      <div class="hero-content">
        <span class="badge">PRO VERSION 2.0</span>
        <h1 class="hero-title">길고 복잡한 주소를<br><span class="gradient-text">단 한 줄의 스마트 링크</span>로</h1>
        <p class="hero-subtitle">
          kfcman.link는 강력한 클릭 트래킹, 커스텀 단축 태그, QR 코드 생성을 지원하는 프리미엄 URL 단축 플랫폼입니다. 마케팅과 비즈니스 성과를 실시간으로 확인해보세요.
        </p>
      </div>

      <!-- URL Input Glassmorphic Card -->
      <div class="shortener-card glass-panel animate-fade-in" id="input-container">
        <form id="shorten-form">
          <!-- Row 1: Original URL Input -->
          <div class="form-row">
            <label for="url-input" class="form-label">축소할 원본 URL 주소</label>
            <div class="input-group">
              <div class="input-icon">
                <i data-lucide="link"></i>
              </div>
              <input type="text" id="url-input" placeholder="https://example.com/very-long-link..." required autocomplete="off">
            </div>
          </div>

          <!-- Row 2: Custom Alias Direct Input -->
          <div class="form-row">
            <label for="custom-alias-input" class="form-label">나만의 단축 주소로 맞춤 지정 (선택 사항)</label>
            <div class="custom-alias-wrapper">
              <div class="custom-alias-group">
                <span class="domain-prefix">kfcman.link /</span>
                <input type="text" id="custom-alias-input" placeholder="원하는-단어-또는-한글" maxlength="16" autocomplete="off">
              </div>
            </div>
            <p class="helper-text">
              * 비워둘 시 임의의 6자리 단축코드가 자동 발급됩니다.<br>
              * 입력 시 한글, 영어 알파벳, 숫자, 하이픈(-), 언더바(_)로 구성된 1~16글자 주소가 됩니다.
            </p>
          </div>

          <!-- Row 3: Standalone Submit Button -->
          <button type="submit" class="btn btn-primary w-full shorten-submit-btn" id="shorten-btn">
            <span>단축 주소 생성하기</span>
            <i data-lucide="arrow-right"></i>
          </button>
        </form>
      </div>

      <!-- Result Card (Initially Hidden) -->
      <div class="result-card glass-panel hidden" id="result-container">
        <div class="result-header">
          <div class="success-icon-badge">
            <i data-lucide="check"></i>
          </div>
          <div>
            <h3 class="result-title">단축 링크 생성 완료!</h3>
            <p class="result-desc">아래의 주소로 손쉽게 공유하고 통계를 확인하세요.</p>
          </div>
        </div>

        <div class="result-body">
          <!-- Real Display Link -->
          <div class="result-link-wrapper">
            <span class="result-label">브랜드 주소</span>
            <div class="result-field">
              <span class="url-display" id="brand-url-display">http://kfcman.link/xxxxxx</span>
              <button class="btn-copy btn-action-icon" data-clipboard-target="brand-url-display" title="복사하기" id="btn-copy-brand">
                <i data-lucide="copy"></i>
              </button>
            </div>
          </div>

          <!-- Real Local Test Link -->
          <div class="result-link-wrapper">
            <span class="result-label">테스트 전용 (로컬/라이브 작동 가능)</span>
            <div class="result-field local-field">
              <span class="url-display" id="local-url-display">http://localhost:3000/xxxxxx</span>
              <button class="btn-copy btn-action-icon" data-clipboard-target="local-url-display" title="복사하기" id="btn-copy-local">
                <i data-lucide="copy"></i>
              </button>
            </div>
          </div>
        </div>

        <div class="result-footer">
          <button class="btn btn-secondary" id="btn-qr-trigger">
            <i data-lucide="qr-code"></i>
            <span>QR 코드 받기</span>
          </button>
          <button class="btn btn-glass" id="btn-reset">
            <i data-lucide="plus-circle"></i>
            <span>새 링크 단축</span>
          </button>
